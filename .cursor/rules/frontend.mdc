## Performance Rules

```tsx
// ✅ FlatList for long lists — virtualized
<FlatList
  data={stores}
  keyExtractor={(item) => item.id}
  renderItem={({ item }) => <StoreCard store={item} />}
  getItemLayout={(_, index) => ({ length: CARD_HEIGHT, offset: CARD_HEIGHT * index, index })}
/>

// ❌ .map() inside ScrollView for long lists — renders ALL at once
<ScrollView>
  {stores.map(store => <StoreCard key={store.id} store={store} />)}
</ScrollView>

// ✅ Memoize expensive components
export const StoreCard = React.memo(({ store }: StoreCardProps) => { ... });

// ✅ useCallback for handlers passed as props
const handleSelect = useCallback(() => onSelect(store.id), [store.id, onSelect]);
```

- Use `FlatList` / `SectionList` when list length is unknown or >20 items
- `React.memo` for components that receive the same props frequently
- Images: always specify `width` + `height` to avoid layout thrash

