# -----------------------------------------------------------------------------
# MealMate — Expo / React Native (public vars only; EXPO_PUBLIC_* được bundle vào app)
# Copy sang .env và điền. Không đặt secret server-only (Kroger secret, service_role) ở đây.
# -----------------------------------------------------------------------------

# Backend API (FastAPI) — ví dụ dev: http://192.168.1.x:8000 hoặc tunnel
EXPO_PUBLIC_API_URL=http://localhost:8000

# Mapbox — cùng token public dùng cho @rnmapbox/maps (Plan §4 Map Engine)
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token

# Supabase — chỉ anon key trên client (Plan §4 Database)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Clerk — Authentication
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
