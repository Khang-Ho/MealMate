{
  "expo": {
    "name": "MealMate",
    "slug": "mealmate",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "mealmate",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "newArchEnabled": true,
    "plugins": [
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsDownloadToken": ""
        }
      ]
    ],
    "android": {
      "package": "com.anonymous.mealmate"
    }
  }
}
