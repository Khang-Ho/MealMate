# -----------------------------------------------------------------------------
# MealMate — biến môi trường (theo Plan.md §4–§5)
# Copy sang .env và điền giá trị thật. Không commit file .env.
# -----------------------------------------------------------------------------

# --- Database (Plan §4: Supabase) ---
# Dùng connection string Postgres từ Supabase (Settings → Database), đổi driver sang asyncpg.
# Ví dụ pooler: postgresql+asyncpg://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# Dev local: giữ URI Docker bên dưới.
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/mealmate

# Supabase — URL + API keys (Settings → API). service_role chỉ dùng trên backend.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Cache (Plan §4) ---
REDIS_URL=redis://localhost:6379

# --- A. Location & mapping (Plan §5) ---
GOOGLE_PLACES_API_KEY=your_google_places_api_key
# Cùng một token cho Mapbox SDK và Directions API (routing có traffic).
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token

# --- B. Inventory & product data (Plan §5) ---
KROGER_CLIENT_ID=your_kroger_client_id
KROGER_CLIENT_SECRET=your_kroger_client_secret
SPOONACULAR_API_KEY=your_spoonacular_api_key
SERPER_API_KEY=your_serper_api_key

# --- C. Intelligence — Gemini 1.5 Flash + LangChain (Plan §5) ---
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# --- D. Authentication — Clerk ---
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key
